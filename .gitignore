# Lab-level ignores — apply to every component subfolder.

# Secrets — never commit, in any component
**/.env

# Local SQLite stores — regenerable, in any component
**/*.db

# Python
**/__pycache__/
*.pyc
.venv/
venv/

# Obsidian vault config (this repo lives inside a OneDrive-synced vault)
.obsidian/
